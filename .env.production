# Production Environment Variables Template
# Coolify will override these with the actual values

# Skip environment validation during build
SKIP_ENV_VALIDATION=true

# NextAuth Configuration (will be overridden by Coolify)
NEXTAUTH_URL=https://almamedia.cl
NEXTAUTH_SECRET=placeholder-will-be-overridden

# Database (will be overridden by Coolify)
DATABASE_URL=postgresql://localhost:5432/almamedia
